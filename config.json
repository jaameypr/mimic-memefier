{
  "face_detector_model": "models/blaze_face_short_range.tflite",
  "face_landmarker_model": "models/face_landmarker.task",
  "hand_landmarker_model": "models/hand_landmarker.task",

  "meme_map": {
    "blushing": "assets/blushing.png",
    "creepedout": "assets/creepedout.png",
    "disgusted": "assets/disgusted.png",
    "fish": "assets/fish.png",
    "funny": "assets/funny.png",
    "neutral": "assets/neutral.png",
    "sleeping": "assets/sleeping.png",
    "ultra_happy": "assets/ultra_happy.png",
    "ultra_laugh": "assets/ultra_laugh.png"
  },

  "thresholds": {
    "eye_closed": 0.018,
    "mouth_open_happy": 0.22,
    "smile_happy": 0.40,
    "smile_disgusted_max": 0.45,
    "mouth_open_disgusted_max": 0.35,
    "brow_disgusted_max": 0.15,
    "mouth_open_funny": 0.20,
    "smile_fish": 0.42,
    "smile_neutral": 0.35,
    "brow_creepedout": 0.070,
    "smile_blushing": 0.30
  },

  "smoothing": {
    "ema_position_alpha": 0.35,
    "ema_feature_alpha": 0.25,
    "stabilizer_window": 12,
    "stabilizer_hold_ms": 450
  },

  "detection": {
    "min_face_detection_confidence": 0.6,
    "num_faces": 1,
    "num_hands": 2,
    "min_hand_detection_confidence": 0.5,
    "min_hand_presence_confidence": 0.5,
    "min_hand_tracking_confidence": 0.5,
    "open_palm_ratio": 1.6
  },

  "overlay": {
    "min_size": 40,
    "max_size": 700,
    "y_offset": -10
  }
}

